<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="720.0" prefWidth="1180.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.FrameController">
   <left>
      <VBox prefWidth="220.0" spacing="12.0" style="-fx-background-color: #1f2937;" BorderPane.alignment="CENTER">
         <padding>
            <Insets bottom="24.0" left="18.0" right="18.0" top="24.0" />
         </padding>
         <children>
            <Label style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: bold;" text="Ponzi Auction" />
            <Label style="-fx-text-fill: #9ca3af; -fx-font-size: 12px;" text="Frontend mockup" />
            <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#showDashboard" prefHeight="42.0" style="-fx-background-color: #f59e0b; -fx-text-fill: #111827; -fx-font-weight: bold;" text="Dashboard" />
            <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#showBrowseAuction" prefHeight="42.0" style="-fx-background-color: #374151; -fx-text-fill: white;" text="Browse Auction" />
            <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#showMySales" prefHeight="42.0" style="-fx-background-color: #374151; -fx-text-fill: white;" text="My Sales" />
            <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#showWatchlist" prefHeight="42.0" style="-fx-background-color: #374151; -fx-text-fill: white;" text="Watchlist" />
         </children>
      </VBox>
   </left>
   <top>
      <HBox alignment="CENTER_LEFT" prefHeight="80.0" style="-fx-background-color: #ffffff; -fx-border-color: #e5e7eb; -fx-border-width: 0 0 1 0;" BorderPane.alignment="CENTER">
         <padding>
            <Insets left="28.0" right="28.0" />
         </padding>
         <children>
            <Label fx:id="sectionTitle" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #111827;" text="Dashboard" />
         </children>
      </HBox>
   </top>
   <center>
      <AnchorPane fx:id="contentArea" style="-fx-background-color: #f3f4f6;" BorderPane.alignment="CENTER" />
   </center>
</BorderPane>
