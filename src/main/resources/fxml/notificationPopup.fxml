<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>

<HBox fx:id="container"
      alignment="CENTER_LEFT"
      maxHeight="80.0"
      maxWidth="320.0"
      minHeight="30.0"
      minWidth="220.0"
      opacity="0.0"
      prefHeight="32.0"
      prefWidth="300.0"
      spacing="6.0"
      xmlns="http://javafx.com/javafx/25"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controller.NotificationPopup">
   <children>
      <Label fx:id="messageLabel"
             maxHeight="54.0"
             maxWidth="278.0"
             style="-fx-text-fill: white; -fx-font-size: 12px;"
             text="Notification"
             wrapText="true" />
   </children>
</HBox>
