<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="620.0" prefWidth="960.0" spacing="20.0" style="-fx-background-color: #f3f4f6;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.BidController">
   <padding>
      <Insets bottom="28.0" left="28.0" right="28.0" top="28.0" />
   </padding>
   <children>
      <HBox alignment="CENTER_LEFT" spacing="12.0">
         <children>
            <Button mnemonicParsing="false" onAction="#back" prefHeight="36.0" prefWidth="100.0" style="-fx-background-color: #374151; -fx-text-fill: white;" text="Back" />
            <Label fx:id="auctionNameLabel" style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #111827;" text="Auction name" />
         </children>
      </HBox>
      <HBox spacing="20.0">
         <children>
            <VBox prefWidth="430.0" spacing="14.0" style="-fx-background-color: white; -fx-background-radius: 16; -fx-border-color: #e5e7eb; -fx-border-radius: 16;">
               <padding>
                  <Insets bottom="22.0" left="22.0" right="22.0" top="22.0" />
               </padding>
               <children>
                  <Label style="-fx-font-size: 18px; -fx-font-weight: bold;" text="Auction Overview" />
                  <Label text="Time left" />
                  <Label fx:id="timeLabel" style="-fx-font-size: 16px;" text="00:00:00" />
                  <Label text="Current bid" />
                  <Label fx:id="currentBidLabel" style="-fx-font-size: 16px;" text="$0.00" />
                  <Label text="Highest bidder" />
                  <Label fx:id="highestBidderLabel" style="-fx-font-size: 16px;" text="Unknown" />
                  <Label text="Total bids" />
                  <Label fx:id="totalBidsLabel" style="-fx-font-size: 16px;" text="0" />
               </children>
            </VBox>
            <VBox prefWidth="430.0" spacing="14.0" style="-fx-background-color: white; -fx-background-radius: 16; -fx-border-color: #e5e7eb; -fx-border-radius: 16;">
               <padding>
                  <Insets bottom="22.0" left="22.0" right="22.0" top="22.0" />
               </padding>
               <children>
                  <Label style="-fx-font-size: 18px; -fx-font-weight: bold;" text="Place Bid" />
                  <Label text="Your latest bid" />
                  <Label fx:id="yourLatestBidLabel" style="-fx-font-size: 16px;" text="No bids yet" />
                  <Label text="Your new bid" />
                  <TextField fx:id="newBidField" promptText="Enter a higher amount" />
                  <Button mnemonicParsing="false" onAction="#placeBid" prefHeight="38.0" prefWidth="160.0" style="-fx-background-color: #f59e0b; -fx-text-fill: #111827; -fx-font-weight: bold;" text="Place Bid" />
                  <Label fx:id="bidStatusLabel" style="-fx-text-fill: #374151;" text="This is a mock bidding screen." wrapText="true" />
                  <Region prefHeight="12.0" />
                  <Label style="-fx-font-size: 18px; -fx-font-weight: bold;" text="Notes" />
                  <Label text="Client-server integration will be connected later." wrapText="true" />
               </children>
            </VBox>
         </children>
      </HBox>
   </children>
</VBox>
