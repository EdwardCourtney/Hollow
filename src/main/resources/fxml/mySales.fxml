<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="620.0" prefWidth="960.0" spacing="16.0" style="-fx-background-color: #f3f4f6;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.MySalesController">
   <padding>
      <Insets bottom="28.0" left="28.0" right="28.0" top="28.0" />
   </padding>
   <children>
      <VBox spacing="14.0" style="-fx-background-color: white; -fx-background-radius: 16; -fx-border-color: #e5e7eb; -fx-border-radius: 16;">
         <padding>
            <Insets bottom="24.0" left="24.0" right="24.0" top="24.0" />
         </padding>
         <children>
            <Label style="-fx-font-size: 24px; -fx-font-weight: bold;" text="Create a New Auction" />
            <Label text="This is a UI-only form for now. Submission is mocked locally." />
            <TextField fx:id="titleField" promptText="Auction title" />
            <TextField fx:id="startPriceField" promptText="Starting price" />
            <TextField fx:id="durationField" promptText="Duration (e.g. 02:00:00)" />
            <TextArea fx:id="descriptionArea" prefHeight="180.0" promptText="Description" wrapText="true" />
            <Button mnemonicParsing="false" onAction="#postAuction" prefHeight="40.0" prefWidth="180.0" style="-fx-background-color: #111827; -fx-text-fill: white; -fx-font-weight: bold;" text="Post Auction" />
            <Label fx:id="statusLabel" style="-fx-text-fill: #374151;" text="No auction has been posted in this mock screen yet." wrapText="true" />
         </children>
      </VBox>
   </children>
</VBox>
